# Workflow engine
WORKFLOW_DATA_ROOT=<path to this project>/data

# Gemini API
NANOBANANA_API_KEY=<your Gemini API key>
NANOBANANA_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# Supported image models: gemini-3.1-flash-image-preview (fast) | gemini-3-pro-image-preview (high quality)
NANOBANANA_MODEL=gemini-3-pro-image-preview
NANOBANANA_DRY_RUN=false

# Admin / Superuser (comma-separated Firebase UIDs — unlimited access, no quota)
# ADMIN_UIDS=

# Logging level (debug | info | warn | error — default: info)
# LOG_LEVEL=debug

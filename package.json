{
  "name": "fashionmentum-image-workflow",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "dev": "pnpm -C packages/web dev",
    "build:core": "pnpm -C packages/workflow-core build",
    "build:web": "pnpm -C packages/web build",
    "test:web": "pnpm -C packages/web test",
    "test:e2e": "pnpm -C packages/web test:e2e"
  },
  "devDependencies": {
    "ts-node": "^10.9.2"
  }
}
